# Public canonical URL used by SEO tags and by generated robots.txt, sitemap.xml, and site.webmanifest.
# Example: https://your-domain.com
# Run npm run generate:public-assets after changing this locally, or let npm run build do it automatically.
NEXT_PUBLIC_SITE_URL=

# Optional webhook for live contact form delivery.
# The API sends a JSON payload with name, email, subject, message, submittedAt, source, and userAgent.
CONTACT_WEBHOOK_URL=

# Optional bearer token for protected webhook endpoints.
CONTACT_WEBHOOK_TOKEN=

# Optional client-side endpoint override. Leave empty to use /api/contact.
NEXT_PUBLIC_CONTACT_ENDPOINT=
